    <geom name="ramp" class="prop" pos="3.13 2.5 -.18" size="1.6 1 .5" euler="0 -0.2 0"/>
    <geom name="hill" class="prop" pos="6 6 -5.5" size="6" type="sphere"/> -->
  </worldbody>

    <default>
    <default class="prop">
      <geom type="box" rgba="0 0.4 1 1"/>
    </default>
    <default class="trunk">
      <geom type="cylinder" rgba="0.35 0.22 0.12 1" friction="1 0.005 0.0001" contype="1"
    conaffinity="1"/>
    </default>
    <default class="rock">
      <geom type="sphere" rgba="0.4 0.4 0.4 1" friction="1 0.01 0.0001"/>
    </default>
    <default class="log">
      <geom type="capsule" rgba="0.30 0.20 0.12 1" friction="1 0.01 0.0001" contype="1"
    conaffinity="1"/>
    </default>
  </default>
</mujoco>