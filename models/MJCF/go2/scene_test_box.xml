<mujoco model="go2 scene">
  <include file="go2.xml"/>

  <statistic center="0 0 0.1" extent="0.8"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="-130" elevation="-20"/>
  </visual>

  <asset>
    <material
    name="green_ground"
    rgba="0.15 0.45 0.20 1"
    reflectance="0.1"/>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
      markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <!-- <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/> -->
    <hfield name="forest"
        file="terrain/forest_hfield.png"
        size="12 12 0.12 0.01"/>  
  </asset>

    <worldbody>
    <!-- <body name="goal_marker" mocap="true" pos="3 0 0.05">
        <geom
            type="sphere"
            size="0.15"
            rgba="0 1 0 0.6"
            contype="0"
            conaffinity="0"/>
    </body> -->

    <light pos="0 0 1.5" dir="0 0 -1" diffuse="0.5 0.5 0.5" specular="0.3 0.3 0.3"
      directional="true" castshadow="false"/>
    <geom name="ground" type="hfield" hfield="forest" pos="0 0 -0.09" material="green_ground" friction="1.0 0.005 0.0001"/>
    <!-- <geom name="floor" size="0 0 0.1" pos="0 0 -0.01" type="plane" material="blue_grid"/> -->
    <!-- <body name="goal" mocap="true" pos=".3 0 0.26">
      <geom size="0.12" contype="0" conaffinity="0" rgba="0 1 0 .5" group="2"/>
    </body> -
    -->
    <!-- <body name="box" mocap="true" pos="1.6 0 0">
      <geom name="box" class="prop" size="0.4 0.4 0.35"/>
    </body> --> 
    <!-- Tree trunks -->
    <geom name="trunk1" class="trunk" pos="2 1 0" size="0.12 1.0"/>
    <geom name="trunk2" class="trunk" pos="-3 -2 0" size="0.10 1.2"/>
    <geom name="trunk3" class="trunk" pos="4 -3 0" size="0.14 0.9"/>
    <geom class="trunk" name="trunk4" pos="-5.0 -3.5 0" size="0.15 1.3"/>
    <geom class="trunk" name="trunk5" pos="6.0  2.5  0" size="0.17 1.6"/>
    <geom class="trunk" name="trunk6" pos="1.5 3.5 0" size="0.15 1.3"/>
    <geom class="trunk" name="trunk7" pos="1.6 0 0" size="0.17 1.6"/>
    <geom class="trunk" name="trunk60"  pos="1.5  1.2  0" size="0.14 1.3"/>
    <geom class="trunk" name="trunk70"  pos="3.5  1.6  0" size="0.15 1.4"/>
    <geom class="trunk" name="trunk80"  pos="6.0  1.3  0" size="0.13 1.2"/>

    <!-- Right side of path -->
    <geom class="trunk" name="trunk9"  pos="2.2 -1.4  0" size="0.14 1.3"/>
    <geom class="trunk" name="trunk10" pos="4.8 -1.7  0" size="0.16 1.5"/>
    <geom class="trunk" name="trunk11" pos="7.0 -1.2  0" size="0.14 1.3"/>

    <!-- Slightly intruding into the corridor (forces planning) -->
    <geom class="trunk" name="trunk12" pos="5.0  0.6  0" size="0.15 1.4"/>
    <geom class="trunk" name="trunk13" pos="8.0 -0.5  0" size="0.13 1.2"/>

    <!-- Off-path background trees (depth & realism) -->
    <geom class="trunk" name="trunk14" pos="1.025  0.047  0" size="0.17 1.6"/>
    <geom class="trunk" name="trunk15" pos="0.932 -0.599  0" size="0.16 1.5"/>
    <!-- Rocks -->
<!-- Rocks -->
    <geom class="rock" name="rock1" pos="0.8  2.8 0.12" size="0.18"/>
    <geom class="rock" name="rock2" pos="-2.2 -1.5 0.10" size="0.14"/>
    <geom class="rock" name="rock3" pos="3.2  -0.5 0.16" size="0.20"/>
   
    <!-- Fallen logs -->
    <geom class="log" name="log1"
          pos="1.0 -4.0 0.12"
          size="0.10 0.9"
          euler="0 0 0.8"/>

    <geom class="log" name="log2"
          pos="-4.0 0.5 0.10"
          size="0.09 1.1"
          euler="0 0 -1.2"/>
